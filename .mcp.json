{
  "mcpServers": {
    "serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant",
        "--project",
        "$(pwd)",
        "--open-web-dashboard",
        "false"
      ],
      "env": {}
    },
    "github": {
      "command": "github-mcp-server",
      "args": ["stdio", "--toolsets", "default,projects"]
    }
  }
}
